# ──────────────────────────────────────────────────
# CMMC Scoreboard — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────

# PostgreSQL connection string
# Azure example:
#   postgresql://username:password@hostname.postgres.database.azure.com:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/cmmc

# Session secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Runtime environment (development | production)
NODE_ENV=development

# Server port (Azure App Service sets this automatically)
PORT=5000

# ──────────────────────────────────────────────────
# Optional: Lead Connector CRM integration
# Leave blank to disable CRM sync on registration
# ──────────────────────────────────────────────────
LEADCONNECTOR_API_KEY=
LEADCONNECTOR_LOCATION_ID=
